# 剪映 PC API（语音字幕识别 recognize_subtitles）
# 使用设备签名，无需 Cookie；设备参数见 ~/.cursor/kb/work/docs/config/jianying-device-info.md
# JIANYING_TDID=420445199538212
# JIANYING_INSTALL_ID=420445199542308
# JIANYING_APP_VERSION=5.9.0
# JIANYING_APP_SDK_VERSION=48.0.0
# JIANYING_PF=3

# 可选：直接注入 VOD 临时凭证（跳过 upload_sign，调试用）
# JIANYING_VOD_ACCESS_KEY_ID=
# JIANYING_VOD_SECRET_ACCESS_KEY=
# JIANYING_VOD_SESSION_TOKEN=

# SSL 校验（企业代理环境可设为 false）
JIANYING_SSL_VERIFY=false
